{
  "name": "@memstack/core",
  "version": "0.6.0",
  "description": "Open-source AI memory framework \u2014 store, retrieve, summarize, and prune memories for LLM agents and games",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npx vitest run --config vitest.e2e.config.ts",
    "test:e2e:run": "bash e2e/run-all.sh",
    "check": "tsc --noEmit",
    "prepublishOnly": "npx tsup src/index.ts --format cjs,esm --dts --clean && npx tsc --noEmit && npx vitest run",
    "publish:all": "pnpm publish -r --access public"
  },
  "keywords": [
    "ai",
    "memory",
    "llm",
    "rag",
    "embeddings",
    "agent",
    "npc",
    "game-dev"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/isiomaC/memstack"
  },
  "bugs": {
    "url": "https://github.com/isiomaC/memstack/issues"
  },
  "homepage": "https://github.com/isiomaC/memstack",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@qdrant/js-client-rest": "^1.18.0",
    "@types/node": "^22.0.0",
    "better-sqlite3": "^11.10.0",
    "chromadb": "^3.4.3",
    "ioredis": "^5.11.1",
    "mongodb": "^7.3.0",
    "neo4j-driver": "^6.1.0",
    "pg": "^8.22.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vectordb": "^0.21.2",
    "vitest": "^1.0.0",
    "weaviate-client": "^3.13.1"
  },
  "files": [
    "dist"
  ]
}
