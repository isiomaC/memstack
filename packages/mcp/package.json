{
  "name": "@memstack/mcp",
  "version": "0.5.0",
  "description": "MCP server for MemStack \u2014 AI agent memory via Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "memstack-mcp": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/isiomaC/memstack"
  },
  "bugs": {
    "url": "https://github.com/isiomaC/memstack/issues"
  },
  "homepage": "https://github.com/isiomaC/memstack",
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts --format esm --dts --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build && pnpm check && pnpm test"
  },
  "dependencies": {
    "@memstack/core": "workspace:*",
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^1.0.0"
  },
  "keywords": [
    "mcp",
    "memory",
    "ai",
    "agent",
    "llm"
  ],
  "license": "MIT"
}
