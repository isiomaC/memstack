{
  "name": "@memstack/server",
  "version": "0.6.0",
  "description": "REST API server for MemStack \u2014 self-hostable agent memory",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/isiomaC/memstack.git"
  },
  "bugs": {
    "url": "https://github.com/isiomaC/memstack/issues"
  },
  "homepage": "https://github.com/isiomaC/memstack",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npx tsc --noEmit && npx vitest run"
  },
  "dependencies": {
    "@memstack/core": "workspace:*",
    "hono": "^4.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^1.0.0",
    "@types/node": "^22.0.0"
  },
  "keywords": [
    "api",
    "memory",
    "ai",
    "agent",
    "rest"
  ],
  "license": "MIT"
}
