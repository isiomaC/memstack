{
  "name": "@memstack/config-env",
  "version": "0.6.4",
  "private": true,
  "description": "Internal — shared environment-variable configuration loader for MemStack's CLI, MCP, and server packages",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/isiomaC/memstack"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "check": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@memstack/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^1.0.0"
  },
  "license": "MIT"
}
